class Solution {
    public int firstUniqChar(String s) {

        int n = s.length();

        HashMap<Character,Integer> hash = new HashMap<>();

        for(int i=0; i<n; i++){
            char ch = s.charAt(i);

            hash.put(ch ,hash.getOrDefault(ch,0)+1);
        }

        for(int i=0; i<n; i++){

            char ch = s.charAt(i);

            if(hash.get(ch)==1){
                return i;
            }

        }

        return -1;
        
    }
}
