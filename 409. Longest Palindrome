class Solution {
    public int longestPalindrome(String s) {

        HashMap<Character,Integer> map = new HashMap<>();

        for(int i=0 ; i<s.length() ; i++){

            char ch = s.charAt(i);
            map.put(ch,map.getOrDefault(ch,0)+1);
        }

        int length=0;
        boolean oddfound=false;

        for(char ch : map.keySet()){
            int freq = map.get(ch);

            if(freq%2==0){
                length+=freq;
            }else{
                length+=freq-1;
                oddfound=true;
            }

            }
             if(oddfound){
                length++;
        }

        return length;
        
    }
}
